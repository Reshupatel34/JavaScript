<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body>
    <div class="w-full h-screen bg-zinc-900 text-white">
        <a class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block" href="/logout">LogOut</a>
    <h3>Profile Page</h3>
    <h3> Hello , <%= user.name %></h3>
    <h5>You can now create your posts</h5>
   
<form action="/posts" method="post">
    <textarea placeholder="What's on your mind ?" class="block p-3 outline-r text-black" ></textarea>
    <input class="px-3 w-40 py-2 text-sm bg-blue-500 block rounded-md mt-2" value="POST" type="submit">
</form>

<div class="posts mt-20">
    <h3 class="text-zinc-400">Your Posts.</h3>
    <div class="postcontainer mt-5">
      <% user.posts.reverse().forEach((post)=>{ %>
           <div class="post w-1/3 p-4 rounded-md border-2 border-zinc-700 bg-zinc-800">
            <h4 class="text-blue-500 mb-2"><%=user.username%></h4>
            <p class="text-sm tracking-tight"><%=post.content%></p>
            <small class="mt-2 inline-block"><%=post.likes.length %>likes</small>
            <div class="btns flex gap-4 mt-1">
                <a class="text-blue-500" href="/like/<%=post._id%>"><%=post.likes.indexOf(user._id)===-1 ? "Like" : "Unlike" %></a>
                <a class="text-zinc-600" href="/edit/<%=post._id%>">edit</a>
            </div>
        </div>
      <%})%>
    </div>
</div>
       </div>
  </body>
</html>
